# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role — used server-side to email ALL admins on investor-triggered
# events (e.g. a new bid). Recommended for the platform features.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — branded status/document emails (no-ops if unset). Create a Resend
# account, verify a sending domain, then set the key + the From address.
# RESEND_API_KEY=re_your_key
# EMAIL_FROM=IONIC Markets <updates@yourdomain.com>

# Anthropic — powers the AI newsfeed (3–7 recent-event bullets via web search).
# ANTHROPIC_API_KEY=sk-ant-your-key
